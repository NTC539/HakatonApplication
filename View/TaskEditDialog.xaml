<Window x:Class="HakatonApplication.View.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование задания" Height="350" Width="500"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock Text="Описание задания" FontWeight="Bold"/>
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                 Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                 Margin="0,5,0,0"/>

        <CheckBox Content="Разрешить публичный просмотр решений" 
                  IsChecked="{Binding IsSolutionsPublic}" Margin="0,15,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="OK" Command="{Binding OkCommand}" Width="75" Margin="5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="75"/>
        </StackPanel>
    </StackPanel>
</Window>