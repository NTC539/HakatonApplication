<Window x:Class="HakatonApplication.View.MarksViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converter="clr-namespace:HakatonApplication.Converter"
        Title="Оценки" Height="500" Width="600" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Команда:"/>
        <ComboBox Grid.Row="0" ItemsSource="{Binding Teams}" DisplayMemberPath="TeamName"
                  SelectedItem="{Binding SelectedTeam}" Margin="0,5,0,10"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Criteria}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCC" BorderThickness="1" Margin="0,5" Padding="8">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <!-- Режим просмотра (средняя оценка) -->
                                <TextBlock Text="{Binding Mark, StringFormat='Средняя оценка: {0:F1}'}" 
                                           Visibility="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                <!-- Режим редактирования (слайдеры) -->
                                <StackPanel Visibility="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider Minimum="0" Maximum="{Binding MaxMark}" Value="{Binding Mark}"
                                            TickFrequency="0.5" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                            Margin="0,5"/>
                                    <TextBlock Text="{Binding Mark, StringFormat='Оценка: {0:F1}'}"/>
                                    <TextBlock Text="Комментарий"/>
                                    <TextBox Text="{Binding Comment}" TextWrapping="Wrap" Height="50"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="Закрыть" Command="{Binding CloseCommand}" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>