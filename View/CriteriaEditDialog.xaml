<Window x:Class="HakatonApplication.View.CriteriaEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование критерия" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="10">
        <TextBlock Text="Критерий (название)" FontWeight="Bold"/>
        <ComboBox ItemsSource="{Binding AvailableCriteria}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding SelectedCriteria}"
                  IsEditable="True"
                  Text="{Binding NewCriteriaName, UpdateSourceTrigger=PropertyChanged}"
                  Margin="0,5,0,10">
            <ComboBox.ToolTip>
                <TextBlock>Выберите существующий критерий или введите новый</TextBlock>
            </ComboBox.ToolTip>
        </ComboBox>

        <TextBlock Text="Описание критерия (детали оценки)" FontWeight="Bold" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                 Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                 Margin="0,5,0,0"/>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,5,0,0" TextWrapping="Wrap"/>
        <TextBlock Text="Максимальный балл" FontWeight="Bold" Margin="0,10,0,0"/>
        <TextBox Text="{Binding MaxMark, UpdateSourceTrigger=PropertyChanged}" 
                 InputScope="Number" Margin="0,5,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="OK" Command="{Binding OkCommand}" Width="75" Margin="5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="75" Margin="5"/>
        </StackPanel>
    </StackPanel>
</Window>