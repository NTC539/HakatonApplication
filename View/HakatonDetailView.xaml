<UserControl x:Class="HakatonApplication.View.HakatonDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:HakatonApplication.Converter">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:NullableDateVisibilityConverter x:Key="NullableDateVisibilityConverter"/>
        <converter:EmptyListVisibilityConverter x:Key="EmptyListVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель: назад + название + описание -->
        <StackPanel Grid.Row="0">
            <Button Content="← Назад к хакатонам" 
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource BackButtonStyle}"/>
            <TextBlock Text="{Binding Name}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="{Binding Description}" FontSize="16" Margin="0,10,0,20"/>
        </StackPanel>

        <!-- Панель редактирования названия/описания (только для организатора) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <TextBox Text="{Binding EditName}" Width="200" Margin="5" 
                     Visibility="{Binding IsOrganizer, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBox Text="{Binding EditDescription}" Width="300" Margin="5" 
                     Visibility="{Binding IsOrganizer, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Content="Сохранить" Command="{Binding SaveHakatonCommand}" 
                    Visibility="{Binding IsOrganizer, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="5"/>
        </StackPanel>

        <!-- Вкладки -->
        <TabControl Grid.Row="2">
            <TabItem Header="Этапы и задания">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Кнопка добавления этапа -->
                        <Button Content="+ Добавить этап" Command="{Binding AddStageCommand}" 
                                HorizontalAlignment="Left" Margin="0,0,0,10"
                                Visibility="{Binding IsOrganizer, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <!-- Список этапов -->
                        <ItemsControl ItemsSource="{Binding Stages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="10">
                                        <StackPanel>
                                            <!-- Кнопки управления этапом -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="✎" Command="{Binding DataContext.EditStageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Редактировать этап" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Button Content="✖" Command="{Binding DataContext.DeleteStageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Удалить этап" Margin="5,0,0,0" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StartDate, StringFormat='dd.MM.yyyy'}" Visibility="{Binding StartDate, Converter={StaticResource NullableDateVisibilityConverter}}"/>
                                                <TextBlock Text=" – " Visibility="{Binding EndDate, Converter={StaticResource NullableDateVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding EndDate, StringFormat='dd.MM.yyyy'}" Visibility="{Binding EndDate, Converter={StaticResource NullableDateVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Заголовок и кнопка добавления задания -->
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                                                <TextBlock Text="Задания:" FontWeight="SemiBold" Visibility="{Binding Tasks, Converter={StaticResource EmptyListVisibilityConverter}}"/>
                                                <Button Content="+ Добавить задание" Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="10,0,0,0" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Список заданий -->
                                            <ItemsControl ItemsSource="{Binding Tasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Margin="0,5,0,5" Padding="8">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                    <Button Content="✎" Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Редактировать задание" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    <Button Content="✖" Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" ToolTip="Удалить задание" Margin="5,0,0,0" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                <Button Content="+ Критерий" Command="{Binding DataContext.AddCriteriaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="0,5,0,5" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <TextBlock Text="Критерии оценки:" FontSize="12" Margin="0,5,0,2" Visibility="{Binding Criteria, Converter={StaticResource EmptyListVisibilityConverter}}"/>
                                                                <ItemsControl ItemsSource="{Binding Criteria}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                                                <TextBlock Text=": "/>
                                                                                <TextBlock Text="{Binding Description}"/>
                                                                                <TextBlock Text=" (макс. "/>
                                                                                <TextBlock Text="{Binding MaxMark}"/>
                                                                                <TextBlock Text=")"/>
                                                                                <Button Content="✎" Command="{Binding DataContext.EditCriteriaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="10,0,0,0" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                                <Button Content="✖" Command="{Binding DataContext.DeleteCriteriaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="5,0,0,0" Visibility="{Binding DataContext.IsOrganizer, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Команды">
                <DataGrid ItemsSource="{Binding Teams}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Участники" Binding="{Binding MembersString}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Призы и спонсоры">
                <DataGrid ItemsSource="{Binding PrizeFunds}" AutoGenerateColumns="True"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>