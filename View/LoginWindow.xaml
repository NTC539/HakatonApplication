<Window x:Class="HakatonApplication.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converter="clr-namespace:HakatonApplication.Converter"
        Title="Хакатон – вход" Height="550" Width="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converter:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="TextBlock" x:Key="ErrorStyle">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Хакатон платформа" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Вход" Click="SwitchMode_Click" Width="100" Margin="0,0,5,0"/>
                <Button Content="Регистрация" Click="SwitchMode_Click" Width="100" Margin="0,0,5,0"/>
            </StackPanel>

            <!-- Режим входа -->
            <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="Email" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Email}" Margin="0,0,0,10"/>
                <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,10"/>
                <Button Content="Войти" Click="Login_Click" Height="35"/>
            </StackPanel>

            <!-- Режим регистрации -->
            <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Фамилия" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RegLastName}" Margin="0,0,0,0"/>
                <TextBlock Text="Имя" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RegFirstName}" Margin="0,0,0,0"/>
                <TextBlock Text="Отчество" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RegPatronymic}" Margin="0,0,0,0"/>
                <TextBlock Text="Email" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RegEmail}" Margin="0,0,0,0"/>
                <TextBlock Text="Телефон (необязательно)" Margin="0,0,0,5"/>
                <TextBox Text="{Binding RegPhone}" Margin="0,0,0,0"/>
                <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="RegPasswordBox" Margin="0,0,0,5"/>
                <TextBlock Text="Повторите пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="RegConfirmPasswordBox" Margin="0,0,0,10"/>
                <Button Content="Зарегистрироваться" Click="Register_Click" Height="35"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorStyle}" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>